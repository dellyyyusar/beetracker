---
export interface Props {
  name: string;
  label?: string;
  required?: boolean;
  class?: string;
  error?: string;
}

const { name, label, required, class: className = '', error } = Astro.props;
---

<div class="space-y-1">
  {label && <label for={name} class="block text-sm font-medium text-gray-700">{label}</label>}
  <select
    {name}
    {required}
    class={`input-field ${className} ${error ? 'border-red-300 focus:border-red-400 focus:ring-red-200' : ''}`}
    id={name}
  >
    <slot />
  </select>
  {error && <p class="text-xs text-red-500 mt-1">{error}</p>}
</div>