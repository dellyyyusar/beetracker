---
import '../styles/global.css';
interface Props {
  title?: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Baby Tracker - Lacak aktivitas bayi Anda" />
    <title>{title ? `${title} | BeeTracker` : 'BeeTracker'}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>