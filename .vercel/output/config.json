{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/activities/new/?$",
			"dest": "_render"
		},
		{
			"src": "^/activities/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/activities/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/activities/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/register/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/babies/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/babies/?$",
			"dest": "_render"
		},
		{
			"src": "^/babies/new/?$",
			"dest": "_render"
		},
		{
			"src": "^/babies/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/babies/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/register/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}